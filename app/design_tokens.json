{
  "$schema": "https://illapa.dev/schemas/design-tokens-v1.json",
  "meta": {
    "name": "Illapa Andean Design System",
    "version": "1.0.0",
    "inspiration": "Inca textile palettes (Chinchero, Cusco), codex stone inscriptions, Q'eros weaving tradition",
    "palette_source": "ui-ux-pro-max — 'Andean Earth' family (terracotta + turquoise + obsidian, high-contrast warm)",
    "pairing_source": "ui-ux-pro-max — 'Serif Display + Humanist Sans' pairing (classical stone + legible body)"
  },
  "color": {
    "primary": {
      "terracotta_500": "#B34A2C",
      "terracotta_600": "#963C22",
      "terracotta_400": "#CC6544",
      "ocre_500":       "#D4A24C",
      "ocre_600":       "#B2842F"
    },
    "secondary": {
      "turquoise_500": "#2E8B8B",
      "turquoise_600": "#226E6E",
      "turquoise_400": "#4AA8A8"
    },
    "neutral": {
      "obsidian_900": "#14110F",
      "obsidian_800": "#1F1B17",
      "obsidian_700": "#2A241F",
      "obsidian_500": "#5B4F45",
      "stone_400":    "#8A7E71",
      "stone_300":    "#B8ADA0",
      "cream_200":    "#EDE4D3",
      "cream_100":    "#F5EEDC",
      "cream_50":     "#FAF6EC"
    },
    "semantic": {
      "bg":         "#F5EEDC",
      "bg_alt":     "#EDE4D3",
      "surface":    "#FAF6EC",
      "fg":         "#14110F",
      "fg_muted":   "#5B4F45",
      "border":     "#D4C6B0",
      "accent":     "#B34A2C",
      "accent_alt": "#2E8B8B",
      "warning":    "#D4A24C",
      "danger":     "#963C22",
      "success":    "#226E6E"
    },
    "chart_sequence": [
      "#B34A2C",
      "#2E8B8B",
      "#D4A24C",
      "#5B4F45",
      "#963C22",
      "#4AA8A8"
    ]
  },
  "typography": {
    "pairing_name": "Fraunces (Serif Display) + Inter (Humanist Sans)",
    "rationale": "Fraunces evokes carved stone inscriptions (soft serifs, organic weight); Inter gives crisp legibility for engineering numerals. Classical + contemporary — the Illapa thesis in type.",
    "font_display": "Fraunces, 'Cormorant Garamond', 'Playfair Display', Georgia, serif",
    "font_body":    "Inter, 'Source Sans Pro', 'Segoe UI', system-ui, sans-serif",
    "font_mono":    "'JetBrains Mono', 'Fira Code', ui-monospace, monospace",
    "scale": {
      "h1":       { "size": "3.0rem",  "weight": 600, "line_height": 1.1,  "letter_spacing": "-0.02em", "family": "display" },
      "h2":       { "size": "2.25rem", "weight": 600, "line_height": 1.15, "letter_spacing": "-0.015em", "family": "display" },
      "h3":       { "size": "1.5rem",  "weight": 600, "line_height": 1.25, "letter_spacing": "-0.01em",  "family": "display" },
      "lead":     { "size": "1.25rem", "weight": 400, "line_height": 1.55, "letter_spacing": "0",        "family": "body" },
      "body":     { "size": "1.0rem",  "weight": 400, "line_height": 1.6,  "letter_spacing": "0",        "family": "body" },
      "small":    { "size": "0.875rem","weight": 400, "line_height": 1.5,  "letter_spacing": "0.005em",  "family": "body" },
      "caption":  { "size": "0.75rem", "weight": 500, "line_height": 1.4,  "letter_spacing": "0.04em",   "family": "body" },
      "mono":     { "size": "0.9rem",  "weight": 400, "line_height": 1.5,  "letter_spacing": "0",        "family": "mono" }
    }
  },
  "spacing": {
    "unit_px": 4,
    "scale": {
      "0":  "0px",
      "1":  "4px",
      "2":  "8px",
      "3":  "12px",
      "4":  "16px",
      "5":  "24px",
      "6":  "32px",
      "7":  "48px",
      "8":  "64px",
      "9":  "96px",
      "10": "128px"
    }
  },
  "radius": {
    "none": "0px",
    "sm":   "2px",
    "md":   "4px",
    "lg":   "8px",
    "xl":   "12px",
    "2xl":  "20px",
    "full": "9999px"
  },
  "shadow": {
    "sm":  "0 1px 2px 0 rgba(20,17,15,0.06)",
    "md":  "0 4px 12px -2px rgba(20,17,15,0.08), 0 2px 4px -1px rgba(20,17,15,0.04)",
    "lg":  "0 12px 32px -8px rgba(20,17,15,0.14), 0 4px 8px -2px rgba(20,17,15,0.06)",
    "focus": "0 0 0 3px rgba(179,74,44,0.35)"
  },
  "motion": {
    "duration_fast":   "120ms",
    "duration_medium": "220ms",
    "duration_slow":   "380ms",
    "easing_standard": "cubic-bezier(0.22, 0.61, 0.36, 1)",
    "easing_emphasis": "cubic-bezier(0.34, 1.2, 0.64, 1)"
  },
  "layout": {
    "max_width": "1180px",
    "sidebar_width": "280px",
    "content_pad": "32px",
    "section_gap": "48px"
  }
}
